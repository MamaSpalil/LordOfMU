#ifndef __CurseFilter_H
#define __CurseFilter_H

#pragma once


#include "PacketFilter.h"
#include <vector>


/**
 * \brief 
 */
class CCurseFilter
	: public CPacketFilter
{
public:
	CCurseFilter(CProxy* pProxy);
	virtual ~CCurseFilter(){}

public:
	// Filter Interface Methods
	virtual const char* GetName(){ return "CurseFilter"; }
	virtual WORD GetLevel(){ return FILTER_LEVEL_ANTIHACK; }
	virtual int FilterRecvPacket(CPacket& pkt, CFilterContext& context);
	virtual int FilterSendPacket(CPacket& pkt, CFilterContext& context);

protected:
	bool FilterMessage(const char* pszMessage);
	void LoadBadWords();

private:
	bool m_fEnabled;
	bool m_fDisconnectOnBadLang;
	int m_iBadLangCount;
	DWORD m_dwLastBadLang;

	std::vector<CStringA> m_vBadWords;
};

#endif //__CurseFilter_H